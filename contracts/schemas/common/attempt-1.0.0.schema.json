{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.m4trust.internal/ai/common/attempt/1.0.0",
  "title": "M4Trust Processing Attempt",
  "description": "At-least-once processing attempt metadata. The relation attemptNumber <= maxAttempts is a runtime semantic check.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "attemptNumber": {"type": "integer", "minimum": 1},
    "maxAttempts": {"type": "integer", "minimum": 1}
  },
  "required": ["attemptNumber", "maxAttempts"]
}
