{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-envelope-1.0.0.schema.json",
  "title": "M4Trust Shared Event Envelope",
  "description": "The common envelope for all M4Trust AI events. The payload is intentionally an object extension point and is constrained by every job-specific event schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {
      "type": "string",
      "enum": ["ai.job.requested.v1", "ai.job.completed.v1", "ai.job.failed.v1", "ai.job.cancel.requested.v1"]
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "Semantic version of the payload contract."
    },
    "occurredAt": {"type": "string", "format": "date-time", "description": "RFC 3339 UTC timestamp."},
    "correlationId": {"type": "string", "format": "uuid"},
    "causationId": {"type": ["string", "null"], "format": "uuid"},
    "jobId": {"type": "string", "format": "uuid"},
    "jobType": {"type": "string", "enum": ["DOCUMENT_EXTRACTION", "VIDEO_ANALYSIS"]},
    "tenantId": {"type": "string", "format": "uuid"},
    "transactionId": {"type": "string", "format": "uuid"},
    "subjectId": {"type": "string", "format": "uuid", "description": "Document or video identifier."},
    "idempotencyKey": {"type": "string", "minLength": 1},
    "producer": {"$ref": "producer-1.0.0.schema.json"},
    "payload": {
      "type": "object",
      "description": "Specialized and strictly constrained by the job-specific event schema."
    }
  },
  "required": [
    "eventId", "eventType", "schemaVersion", "occurredAt", "correlationId", "causationId", "jobId", "jobType", "tenantId", "transactionId", "subjectId", "idempotencyKey", "producer", "payload"
  ]
}
