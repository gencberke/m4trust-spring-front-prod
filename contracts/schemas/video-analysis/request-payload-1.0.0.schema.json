{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "request-payload-1.0.0.schema.json",
  "title": "M4Trust Video Analysis Request Payload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "videoId": {"type": "string", "format": "uuid"},
        "fileName": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 1},
        "sizeBytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "download": {"$ref": "../common/download-reference-1.0.0.schema.json"}
      },
      "required": ["videoId", "fileName", "mediaType", "sizeBytes", "sha256", "download"]
    },
    "processing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysisProfile": {"const": "DELIVERY_EVIDENCE_DEFAULT"},
        "expectedObjects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string", "minLength": 1},
              "expectedCount": {"type": "integer", "minimum": 0}
            },
            "required": ["label", "expectedCount"]
          },
          "maxItems": 100
        },
        "requestedOutputSchema": {"const": "m4trust.video-analysis-result"},
        "requestedOutputSchemaVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"}
      },
      "required": ["analysisProfile", "expectedObjects", "requestedOutputSchema", "requestedOutputSchemaVersion"]
    },
    "deadlineAt": {"type": "string", "format": "date-time", "description": "RFC 3339 UTC processing deadline."}
  },
  "required": ["input", "processing", "deadlineAt"]
}
